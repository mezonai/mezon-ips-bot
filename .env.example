APP_ENV=dev
MEZON_CLIENT_ID=your-mezon-client-id
MEZON_API_KEY=your-mezon-api-key
# Database URI (Use sqlite+aiosqlite for SQLite, or postgresql+asyncpg for PostgreSQL)
# Note: Docker Compose will automatically use PostgreSQL by default unless DB_URI is explicitly set in .env to another path.
# If running SQLite inside Docker, make sure to mount a volume and use an absolute persistent path (e.g., sqlite+aiosqlite:////app/data/ips-bot.db).
DB_URI=postgresql+asyncpg://postgres:postgres@localhost:5432/ips-bot

# Bot behavior: set to true to only respond when mentioned (@Bot)
# MEZON_BOT_REQUIRE_MENTION=true

# Bot behavior: set to true to only respond when explicitly mentioned (@Bot)
# Default: false (responds to both direct commands and mentions)
MEZON_BOT_REQUIRE_MENTION=false

# Optional S3-compatible storage settings (leave empty if not used)
# S3_ENDPOINT_URL=https://<your-s3-endpoint>
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_BUCKET_NAME=your-bucket
# S3_REGION=auto
# S3_PUBLIC_URL_BASE=https://<your-public-base-url>
