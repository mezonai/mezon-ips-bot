APP_ENV=prod
MEZON_CLIENT_ID=your-production-mezon-client-id
MEZON_API_KEY=your-production-mezon-api-key
MEZON_BOT_REQUIRE_MENTION=true

# Database URI (Use sqlite+aiosqlite for SQLite, or postgresql+asyncpg for PostgreSQL)
# Note: Docker Compose will automatically use PostgreSQL by default unless DB_URI is explicitly set to another path.
# If deploying SQLite inside Docker, make sure to mount a volume and use an absolute persistent path (e.g., sqlite+aiosqlite:////app/data/ips-bot.db).
DB_URI=sqlite+aiosqlite:///ips-bot.db

# Optional: PostgreSQL values (Used if docker-compose.prod.yml is active for PostgreSQL)
# POSTGRES_DB=ips-bot
# POSTGRES_PASSWORD=change-me
APP_WORKERS=2

# Optional S3-compatible storage settings (leave empty if not used)
# S3_ENDPOINT_URL=https://<your-s3-endpoint>
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_BUCKET_NAME=your-bucket
# S3_REGION=auto
# S3_PUBLIC_URL_BASE=https://<your-public-base-url>
